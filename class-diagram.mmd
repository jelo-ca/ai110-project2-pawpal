---
config:
  look: neo
  theme: mc
---
classDiagram
    class User {
        +uid: string
        +name: string
        +address: string
        +phoneNumber: string
        +timezone: string
        +pets: List~Pet~
        +tasks: List~Task~
        +addPet(p: Pet): void
        +removePet(petId: string): void
        +addTask(t: Task): bool
        +editTask(taskId: string, updates: Map): bool
        +deleteTask(taskId: string): bool
        +hasTaskConflict(candidate: Task): bool
        +getTasksByPet(petId: string): List~Task~
    }

    class Pet {
        +uid: string
        +name: string
        +animalId: string
        +age: int
        +birthDate: date
        +weight: float
        +medicalNotes: string
        +updateInfo(name: string, animalId: string, age: int): void
        +calculateAge(today: date): int
        +getUpcomingTasks(tasks: List~Task~): List~Task~
    }

    class Animal {
        +uid: string
        +type: string
        +breed: string
        +displayName(): string
    }

    class Task {
        +uid: string
        +name: string
        +description: string
        +associated_pet_id: string
        +type: string
        +duration: int
        +start_date: date
        +end_date: date
        +start_time: time
        +end_time: time
        +status: string
        +priority: string
        +reminderMinutesBefore: int
        +isRecurring: bool
        +recurrenceRule: string
        +add(): void
        +edit(updates: Map): void
        +delete(): void
        +validateTimeRange(): bool
        +overlapsWith(other: Task): bool
        +getStartDateTime(): datetime
        +getEndDateTime(): datetime
    }

    class Scheduler {
        +scheduleTask(user: User, task: Task): bool
        +findConflicts(user: User, task: Task): List~Task~
        +suggestNextSlot(user: User, duration: int, windowDays: int): datetime
        +getDailySchedule(user: User, date: date): List~Task~
        +cancelTask(taskId: string): bool
    }

    User "1" --> "0..*" Pet : owns
    User "1" --> "0..*" Task : manages
    Pet "1" --> "1" Animal : species
    Task "1" --> "1" Pet : associated_pet
    Scheduler "1" --> "0..*" Task : schedules
    Scheduler "1" --> "1" User : for